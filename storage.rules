rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profil fotoğrafları (dosya adı: {uid}.jpg):
    // - Herkes okuyabilir (profil resmi göstermek için)
    // - Sadece dosya sahibi yazabilir/silebilir
    // Not: Storage kurallarında bir {wildcard} tam bir yol segmenti olmalıdır;
    // bu yüzden "{uid}.jpg" yerine tüm dosya adı {imageId} ile yakalanır ve
    // uid + '.jpg' ile karşılaştırılır.
    // Yazma sınırları: dosya 5 MB'tan küçük olmalı ve içerik tipi bir görsel
    // (image/*) olmalı. Böylece keyfi/aşırı büyük dosya yüklemesi engellenir.
    match /profile_photos/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
                   && imageId == request.auth.uid + '.jpg'
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Kapak fotoğrafları (dosya adı: {uid}.jpg) — profil fotoğrafıyla aynı kural.
    match /cover_photos/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
                   && imageId == request.auth.uid + '.jpg'
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Diğer tüm dosyalar varsayılan olarak kapalı
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
