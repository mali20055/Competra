          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "competra-9e396",
          "configurations": {
            "android": "1:1016063457655:android:d23432853adc7043e14972",
            "ios": "1:1016063457655:ios:fac4f0b30dfbea06e14972"
          }
        }
      }
    }
  },
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "storage": { "port": 9199 },
